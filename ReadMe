## Using the prototype without an Arduino
This prototype is mainly designed to be controlled with a physical control panel. When this panel is not connected, the prototype works with limited functionality and the three factors cannot be set manually.

To still view the prototype and test the interface, an alternative control method is built in: use the **`9`** key on your keyboard to navigate through the different pages.


## Starting the code
To run the prototype locally, you can use the Live Server extension in Visual Studio Code.

1. Open the project folder in Visual Studio Code.
2. Click on **"Go Live"** in the bottom right corner.
3. The prototype will now open automatically in your default web browser.


## Use of AI tools
**GitHub Copilot** was used during the development of this prototype. This AI assistant helped to write code more efficiently and to speed up the overall development process and the creation of the prototype.


## Code for the Arduino
If you do have the hardware connected (the Arduino and all necessary components), the corresponding software needs to be loaded. Copy the code below into the Arduino IDE and upload it to the board to connect it with the control panel.

// --- BIG BUTTON VARIABLES ---
const int buttonPin = 2; 
int buttonState = 0;         
int lastButtonState = HIGH;  

// --- POTENTIOMETER VARIABLES (Replaces the Rotary Encoder) ---
const int potPin = A2; // The middle pin of the B10K
int lastPotValue = -100; 

// --- SLIDER VARIABLES ---
const int slider1Pin = A1;
const int slider2Pin = A0;
int lastSlider1Value = -100; 
int lastSlider2Value = -100;

void setup() {
  Serial.begin(9600);
  
  pinMode(buttonPin, INPUT_PULLUP); 
  // Analog pins (A0, A1, A2) do not need to be explicitly declared as INPUT in the setup.
}

void loop() {
  // -------------------------
  // 1. BIG BUTTON LOGIC
  // -------------------------
  buttonState = digitalRead(buttonPin);
  if (buttonState != lastButtonState) {
    if (buttonState == LOW) { 
      Serial.println("PRESSED");
    } 
    delay(150); 
  }
  lastButtonState = buttonState;

  // -------------------------
  // 2. POTENTIOMETER LOGIC (New)
  // -------------------------
  int rawPot = analogRead(potPin);
  
  // Map the raw value (0-1023) to 0-100, just like your old encoder
  int currentPot = map(rawPot, 0, 1023, 100, 0);
  
  // Check if the value has changed (with a small margin against noise)
  if (abs(currentPot - lastPotValue) > 1) {
    Serial.println(currentPot);
    lastPotValue = currentPot;
  }

  // -------------------------
  // 3. SLIDER 1 LOGIC (Input 1)
  // -------------------------
  int rawSlider1 = analogRead(slider1Pin);
  
  // FIXED: Flipped 0, 1000 to 1000, 0 to invert the slider direction
  int currentSlider1 = map(rawSlider1, 0, 1023, 1000, 0);
  
  // SNAP ZONES: Force to exactly 0 or 1000 at the ends
  if (currentSlider1 < 15) {
    currentSlider1 = 0;
  } else if (currentSlider1 > 985) {
    currentSlider1 = 1000;
  }
  
  if (abs(currentSlider1 - lastSlider1Value) > 5) {
    Serial.print("S1:");            
    Serial.println(currentSlider1); 
    lastSlider1Value = currentSlider1;
  }

  // -------------------------
  // 4. SLIDER 2 LOGIC (Input 2)
  // -------------------------
  int rawSlider2 = analogRead(slider2Pin);
  
  // FIXED: Flipped 0, 1000 to 1000, 0 to invert the slider direction
  int currentSlider2 = map(rawSlider2, 0, 1023, 1000, 0);
  
  // SNAP ZONES: Force to exactly 0 or 1000 at the ends
  if (currentSlider2 < 15) {
    currentSlider2 = 0;
  } else if (currentSlider2 > 985) {
    currentSlider2 = 1000;
  }
  
  if (abs(currentSlider2 - lastSlider2Value) > 5) {
    Serial.print("S2:");            
    Serial.println(currentSlider2); 
    lastSlider2Value = currentSlider2;
  }
}